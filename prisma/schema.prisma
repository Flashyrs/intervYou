generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  sessions          Session[]
  accounts          Account[]
  createdAt         DateTime           @default(now())
  interviewSessions InterviewSession[] @relation("InterviewParticipants")
  submissions       Submission[]
  participantEvents ParticipantEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id            String   @id @default(cuid())
  userId        String
  sessionToken  String   @unique
  interviewerId String?
  intervieweeId String?
  createdAt     DateTime @default(now())
  expires       DateTime
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterviewSession {
  id                  String    @id @default(cuid())
  createdBy           String
  createdAt           DateTime  @default(now())
  problemId           String?
  participants        User[]    @relation("InterviewParticipants")
  liveStateVersion    Int       @default(0)
  stateSnapshot       Json?
  finalState          Json?
  problemPack         Json?
  interviewerNotes    String?   @db.Text
  stateSnapshotUpdatedAt DateTime?
  
  // Scheduling fields
  scheduledFor        DateTime?
  isScheduled         Boolean   @default(false)
  inviteeEmail        String?
  inviteeName         String?

  // Session expiration fields
  status              String    @default("active") // "active", "expired", "scheduled", "completed"
  startedAt           DateTime?
  endedAt             DateTime?
  lastActiveAt        DateTime?
  submissions         Submission[]
  participantEvents   ParticipantEvent[]
  
  @@index([status])
  @@index([scheduledFor])
  @@index([createdBy, createdAt])
  @@index([inviteeEmail])
  @@index([createdAt])
}
model Submission {
  id          String   @id @default(cuid())
  sessionId   String
  problemId   String
  userId      String
  language    String
  code        String
  problemText String?  // Store the problem description
  passed      Boolean
  attempts    Int      @default(1)
  time        Float?   // Execution time in milliseconds
  memory      Float?   // Memory used in kilobytes
  testResults TestCaseResult[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, problemId, userId])  // one row per user/problem/session
  @@index([sessionId, userId])
  @@index([sessionId, updatedAt])
  @@index([userId, createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ExecutionLog {
      id         String   @id @default(cuid())
      sessionId  String
      userId     String
      problemId  String
      createdAt  DateTime @default(now())

      @@unique([sessionId, userId, problemId])
      @@index([sessionId, userId])
    }

model ParticipantEvent {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  eventType String   // "JOINED", "LEFT"
  timestamp DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}

model TestCaseResult {
  id             String   @id @default(cuid())
  submissionId   String
  passed         Boolean
  time           Float?
  memory         Float?
  stdout         String?  @db.Text
  error          String?  @db.Text
  expectedOutput String?  @db.Text
  actualOutput   String?  @db.Text
  createdAt      DateTime @default(now())

  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}
